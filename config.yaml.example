domain: tunnel.example.com
email: admin@example.com

backend_host: 127.0.0.1
backend_port: 109

proxy:
  listen_host: 127.0.0.1
  listen_port: 8888
  idle_timeout_seconds: 180
  shared_pass: ""

api:
  listen_host: 127.0.0.1
  listen_port: 8080
  token: "your-secure-token"

nginx:
  http_ports: [80, 8080]
  tls_ports: [443, 8443]

cert_method: le_http01
cf_api_token: ""
cf_email: ""
cf_global_api_key: ""

database: /var/lib/tunnelgate/users.db

log_level: info
log_format: text
